{
  "output": {
    "filePath": "repomix-output.xml",
    "style": "xml"
  },
  "include": [
    "src/**/*",
    "prisma/**/*",
    "package.json",
    "package-lock.json",
    "tsconfig.json",
    "next.config.*",
    "middleware.*",
    "Dockerfile",
    "docker-compose.*",
    ".dockerignore",
    ".env.example",
    ".npmrc",
    "postcss.config.*",
    "tailwind.config.*",
    "eslint.config.*",
    ".eslintrc.*",
    "jest.config.*",
    "playwright.config.*",
    "vitest.config.*",
    "railway.*",
    "Procfile",
    "README.md"
  ],
  "ignore": {
    "useGitignore": false,
    "useDefaultPatterns": false,
    "customPatterns": [
      "node_modules/**",
      ".next/**",
      "dist/**",
      "build/**",
      "coverage/**",
      "storage/**",
      "logs/**",
      ".git/**"
    ]
  }
}
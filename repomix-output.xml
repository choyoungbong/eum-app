// src/lib/validators.ts
// Zod 기반 API 입력값 스키마 정의
// npm install zod

import { z } from "zod";
import { NextRequest } from "next/server";
import { ApiError } from "@/lib/api-response";
import type { NextResponse } from "next/server";

// ── 공통 스키마 ──────────────────────────────────────────
export const paginationSchema = z.object({
